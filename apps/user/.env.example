# API base URL
VITE_API_BASE_URL=
# API prefix path
VITE_API_PREFIX=

# CDN URL — leave EMPTY to disable all CDN-backed features (remote tutorial).
# Only set this if you self-host a mirror of perfect-panel/ppanel-tutorial.
VITE_CDN_URL=

# Enable tutorial document feature (true/false). Requires VITE_CDN_URL to be set.
VITE_TUTORIAL_DOCUMENT=false

# Show landing page on home route (true/false, default: true)
# When set to false, users will be redirected to login page directly
VITE_SHOW_LANDING_PAGE=true

# Default login credentials (for development only)
VITE_USER_EMAIL=
VITE_USER_PASSWORD=
